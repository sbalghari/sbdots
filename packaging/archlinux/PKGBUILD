# Maintainer: Saifullah Balghari

pkgname=sbdots-git
pkgver=r276.e0beb67
pkgrel=1
pkgdesc="A Modern, Feature-Rich, and Polished Hyprland Setup"
arch=('x86_64')
url="https://github.com/sbalghari/sbdots"
license=('GPL-3.0')


depends=(
  atuin
  power-profiles-daemon
  hyprpolkitagent
  breeze-icons
  breeze-gtk 
  awww
  blueman
  brightnessctl
  btop
  eza
  fastfetch
  figlet
  fish
  gnome-keyring
  hypridle
  hyprlock
  hyprpicker
  hyprshot
  kitty
  kwalletmanager
  noto-fonts
  pacman-contrib
  pavucontrol
  polkit-kde-agent
  python-pexpect
  python-psutil
  python-pyfiglet
  python-requests
  python-rich
  python-setproctitle
  python-typer
  rofi
  starship
  swaync
  tela-circle-icon-theme-standard
  ttf-dejavu
  ttf-jetbrains-mono
  ttf-jetbrains-mono-nerd
  udiskie
  uwsm
  waybar
  wl-clipboard
)

makedepends=(
  git
  python-build
  python-installer
  python-wheel
  python-setuptools
  gcc
)

source=(
  "git+https://github.com/sbalghari/sbdots.git"
)

sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/sbdots"

  printf "r%s.%s" \
    "$(git rev-list --count HEAD)" \
    "$(git rev-parse --short HEAD)"
}

build() {
  cd "$srcdir/sbdots"

  # build python wheel
  python -m build --wheel --no-isolation

  # build cpp binary
  g++ bin/sbdots-actions.cpp -o sbdots-actions
}

package() {
  cd "$srcdir/sbdots"

  # install python wheel
  python -m installer \
    --destdir="$pkgdir" \
    dist/*.whl

  # dotfiles
  install -dm755 "$pkgdir/usr/share/sbdots"

  cp -r dotfiles/. \
    "$pkgdir/usr/share/sbdots/"

  # install shell/python scripts from bin
  for file in bin/*; do
    [[ "$file" == *.cpp ]] && continue
    install -Dm755 "$file" "$pkgdir/usr/bin/$(basename "$file")"
  done

  # install compiled cpp binary
  install -Dm755 \
    sbdots-actions \
    "$pkgdir/usr/bin/sbdots-actions"

  # install default  configs
  install -dm755 "$pkgdir/etc/sbdots"
  cp -r configs/. \
    "$pkgdir/etc/sbdots/"

  # install app icon
  install -Dm644 \
    "assets/sbdots.svg" \
    "$pkgdir/usr/share/icons/hicolor/scalable/apps/sbdots.svg"

  # install systemd services - user
  install -dm755 "$pkgdir/usr/lib/systemd/user"
  install -Dm644 services/*.service \
    "$pkgdir/usr/lib/systemd/user/"
}

