makedepends=(
  git
  python-build
  python-installer
  python-wheel
  python-setuptools
  gcc
)

source=(
  "git+https://github.com/sbalghari/sbdots.git#branch=refactor/module-restructure"
)

sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/sbdots"

  printf "r%s.%s" \
    "$(git rev-list --count HEAD)" \
    "$(git rev-parse --short HEAD)"
}

build() {
  cd "$srcdir/sbdots"

  # build python wheel
  python -m build --wheel --no-isolation

  # build cpp binary
  g++ bin/sbdots-actions.cpp -o sbdots-actions
}

package() {
  cd "$srcdir/sbdots"

  # install python wheel
  python -m installer \
    --destdir="$pkgdir" \
    dist/*.whl

  # dotfiles
  install -dm755 "$pkgdir/usr/share/sbdots"

  cp -r dotfiles/. \
    "$pkgdir/usr/share/sbdots/"

  # install shell/python scripts from bin
  for file in bin/*; do
    [[ "$file" == *.cpp ]] && continue
    install -Dm755 "$file" "$pkgdir/usr/bin/$(basename "$file")"
  done

  # install compiled cpp binary
  install -Dm755 \
    sbdots-actions \
    "$pkgdir/usr/bin/sbdots-actions"

  # install app icon
  install -Dm644 \
    "assets/sbdots.svg" \
    "$pkgdir/usr/share/icons/hicolor/scalable/apps/sbdots.svg"
}