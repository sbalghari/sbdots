# Maintainer: Saifullah Balghari

pkgname=sbdots-git
pkgver=r276.e0beb67
pkgrel=1
pkgdesc="A Modern, Feature-Rich, and Polished Hyprland Setup"
arch=('x86_64')
url="https://github.com/sbalghari/sbdots"
license=('GPL-3.0')


depends=(
  atuin
  power-profiles-daemon
  hyprpolkitagent
  aur-check-updates
  awww
  bibata-cursor-theme-bin
  blueman
  brightnessctl
  btop
  cava
  eza
  fastfetch
  figlet
  fish
  gnome-keyring
  hypridle
  hyprlock
  hyprpicker
  hyprshade
  hyprshot
  kitty
  kwalletmanager
  noto-fonts
  pacman-contrib
  pavucontrol
  polkit-kde-agent
  python-pexpect
  python-psutil
  python-pyfiglet
  python-pywal
  python-requests
  python-rich
  python-setproctitle
  python-typer
  rofi
  starship
  swaync
  tela-circle-icon-theme-standard
  ttf-dejavu
  ttf-jetbrains-mono
  ttf-jetbrains-mono-nerd
  udiskie
  uwsm
  waybar
  waypaper
  wlogout
)

makedepends=(
  git
  python-build
  python-installer
  python-wheel
  python-setuptools
)

source=(
  "git+https://github.com/sbalghari/sbdots.git"
)

sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/sbdots"

  printf "r%s.%s" \
    "$(git rev-list --count HEAD)" \
    "$(git rev-parse --short HEAD)"
}

build() {
  cd "$srcdir/sbdots"

  python -m build --wheel --no-isolation
}

package() {
  cd "$srcdir/sbdots"

  # install python wheel
  python -m installer \
    --destdir="$pkgdir" \
    dist/*.whl

  # dotfiles
  install -dm755 "$pkgdir/usr/share/sbdots"

  cp -r dotfiles/. \
    "$pkgdir/usr/share/sbdots/"

  # bin scripts
  install -Dm755 bin/* "$pkgdir/usr/bin/"
  
  # install app icon
  install -Dm644 \
    "assets/sbdots.svg" \
    "$pkgdir/usr/share/icons/hicolor/scalable/apps/sbdots.svg"
}
