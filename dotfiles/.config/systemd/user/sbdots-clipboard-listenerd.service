[Unit]
Description=SBDots Clipboard Listener (wl-based) Daemon
After=graphical.target
Wants=graphical.target

[Service]
Type=simple

ExecStart=/usr/bin/python -m sbdots.daemons.cliplistener_d

Environment=PYTHONUNBUFFERED=1
Environment=PYTHONPATH=/usr/lib/sbdots

Restart=always
RestartSec=1

StandardOutput=journal
StandardError=journal

NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=default.target